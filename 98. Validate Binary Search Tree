class Solution:
    def isValidBST(self, root):
        def helper(node, low=float('-inf'), high=float('inf')):
            if not node:
                return True
            val = node.val
            if val <= low or val >= high:
                return False
            # Check left and right subtrees
            return helper(node.left, low, val) and helper(node.right, val, high)
        
        return helper(root)
